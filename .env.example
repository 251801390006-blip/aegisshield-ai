# ── AegisShield AI – Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.

# Flask
FLASK_ENV=production
SECRET_KEY=your-super-secret-key-change-this-immediately

# Database (Render provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@host:5432/aegisshield

# Mail (for password reset emails)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@aegisshield.io

# Redis (optional – for rate limiting in production)
REDIS_URL=redis://localhost:6379/0

# Security
WTF_CSRF_ENABLED=true
SESSION_COOKIE_SECURE=true
